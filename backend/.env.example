# Puerto del backend Express
PORT=4000

# Proyecto de Firebase / GCP
FIREBASE_PROJECT_ID=rumboapp-264ca

# Ruta al service account key (JSON). NUNCA se commitea.
# Descarga el archivo desde: Firebase Console -> Configuración del proyecto
# -> Cuentas de servicio -> Generar nueva clave privada.
SERVICE_ACCOUNT_PATH=./serviceAccountKey.json

# Orígenes permitidos por CORS (separados por coma). En dev es el Next.js local.
CORS_ORIGINS=http://localhost:3000

# --- Se usarán en días posteriores ---
# GEMINI_API_KEY se leerá de Secret Manager en producción (Día 8).
